# OpenAI-compatible VLM API settings.
# If your company API is OpenAI-compatible, set VLM_API_STYLE=openai.
# If it expects a simple POST JSON payload, set VLM_API_STYLE=requests.
VLM_API_STYLE=openai
API_KEY=replace-with-your-api-key
BASE_URL=https://your-company-vlm-endpoint.example.com/compatible-mode/v1
MODEL_NAME=qwen3.7-plus

# Only used when VLM_API_STYLE=requests.
# The client sends: {"model": MODEL_NAME, "prompt": ..., "image": "data:image/...;base64,..."}
VLM_ENDPOINT=https://api.example.com/v1/chat/completions

# Optional runtime defaults.
REQUEST_TIMEOUT=60
MAX_RETRIES=3
